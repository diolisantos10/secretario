{
  "name": "secretario",
  "version": "0.1.0",
  "private": true,
  "description": "Secretário pessoal no WhatsApp (Meta Cloud API) movido a Claude — memória, lembretes, agenda e busca na web.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "prisma db push --skip-generate && tsx src/index.ts",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@prisma/client": "^5.16.1",
    "openai": "latest",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "googleapis": "latest",
    "node-cron": "^3.0.3",
    "tsx": "^4.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.16.1",
    "typescript": "^5.5.3"
  }
}
