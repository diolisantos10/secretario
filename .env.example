# ============================================================================
# Secretário pessoal — variáveis de ambiente
# Copie para .env (local) ou cadastre no Railway. Só DATABASE_URL é obrigatória
# para o serviço subir; o resto é a SUA parte (credenciais) e pode entrar depois.
# ============================================================================

# --- Infra (obrigatório) ----------------------------------------------------
# No Railway, adicione o plugin PostgreSQL e use a referência ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:pass@host:5432/secretario"
# A porta é injetada pelo Railway automaticamente; localmente pode deixar 8080
PORT=8080
# URL pública do serviço (usada no link de conexão da agenda). Ex.: https://secretario.up.railway.app
PUBLIC_URL=""
LOG_LEVEL="info"

# --- Você (o dono) ----------------------------------------------------------
# Seu número no WhatsApp, só dígitos, com país e DDD. Ex.: 5511999998888
OWNER_WHATSAPP=""
OWNER_NAME="Dió"
TIMEZONE="America/Sao_Paulo"
# Horário do briefing matinal (HH:MM no fuso acima). Deixe vazio para desligar.
BRIEFING_TIME="07:30"

# --- Claude (Anthropic) -----------------------------------------------------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
ANTHROPIC_EFFORT="high"     # low | medium | high | xhigh | max
ENABLE_WEB_SEARCH="true"

# --- Meta WhatsApp Cloud API ------------------------------------------------
# Do app no developers.facebook.com → WhatsApp → API Setup
META_PHONE_NUMBER_ID=""
META_ACCESS_TOKEN=""        # token permanente (System User), não o temporário de 24h
META_APP_SECRET=""          # Configurações → Básico → Chave Secreta do App
META_VERIFY_TOKEN=""        # uma senha que VOCÊ inventa; repita no painel do webhook
META_GRAPH_VERSION="v21.0"

# --- Agenda (Google Calendar) — opcional, pode conectar depois --------------
# Chave de 32 bytes para cifrar os tokens. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Deve bater EXATAMENTE com o redirect autorizado no Google Cloud Console:
#   {PUBLIC_URL}/oauth/google/callback
GOOGLE_REDIRECT_URI=""
